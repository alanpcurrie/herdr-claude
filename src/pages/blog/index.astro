---
// OWNER: Agent 5 (blog index). Lists all posts as elegant cards, newest first.
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../utils/paths';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---
<BaseLayout title="Blog" description="Field notes from a demo that documents the very tools building it — herdr, Claude Code, AI subagents, and git worktrees.">
  <header class="page-head">
    <p class="eyebrow">/blog</p>
    <h1>Field notes</h1>
    <p class="lede">
      A meta dev blog about <strong>herdr</strong>, Claude Code, AI subagents,
      and git worktrees — written while the demo builds itself.
    </p>
  </header>

  <ul class="post-list">
    {posts.map((p) => (
      <li class="post-card">
        <a class="card-link" href={withBase(`/blog/${p.id}`)}>
          <time class="card-date" datetime={p.data.pubDate.toISOString()}>
            {dateFmt.format(p.data.pubDate)}
          </time>
          <h2 class="card-title">{p.data.title}</h2>
          <p class="card-desc">{p.data.description}</p>
          {p.data.tags?.length > 0 && (
            <ul class="card-tags">
              {p.data.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )}
          <span class="card-cue" aria-hidden="true">Read post →</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }
  .page-head h1 {
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }
  .lede {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 40ch;
    margin: 0;
  }
  .lede strong {
    color: var(--fg);
    font-weight: 600;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.25rem;
  }

  .post-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 12px 30px -18px var(--accent);
  }

  .card-link {
    display: block;
    padding: 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .card-date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }
  .card-title {
    font-size: 1.35rem;
    line-height: 1.25;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .post-card:hover .card-title {
    color: var(--accent);
  }
  .card-desc {
    color: var(--muted);
    margin: 0 0 1rem;
  }

  .card-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
    padding: 0;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-2) 30%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
  }

  .card-cue {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .post-card:hover .card-cue {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 480px) {
    .card-link { padding: 1.25rem; }
  }
</style>
