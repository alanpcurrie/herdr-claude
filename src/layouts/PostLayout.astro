---
// OWNER: Agent 5 (post layout). Clean, readable long-form article layout.
// CONTRACT: takes a CollectionEntry<'blog'>.data as `frontmatter`, renders <slot/> as post body.
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../utils/paths';

interface Props {
  frontmatter: { title: string; description: string; pubDate: Date; tags: string[] };
}
const { frontmatter } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(frontmatter.pubDate);
---
<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="post">
    <header class="post-head">
      <a class="back-link" href={withBase("/blog")}>← Back to blog</a>
      <h1>{frontmatter.title}</h1>
      <div class="post-meta">
        <time datetime={frontmatter.pubDate.toISOString()}>{formattedDate}</time>
        {frontmatter.tags?.length > 0 && (
          <ul class="post-tags">
            {frontmatter.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="post-foot">
      <a class="back-link" href={withBase("/blog")}>← Back to blog</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    display: block;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover {
    color: var(--accent);
  }

  .post-head {
    margin-bottom: 2.5rem;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--border);
  }
  .post-head h1 {
    font-size: clamp(2rem, 5.5vw, 3rem);
    line-height: 1.12;
    letter-spacing: -0.025em;
    margin: 1.25rem 0 1rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .post-meta time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
  }
  .post-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent-2);
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-2) 30%, transparent);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
  }

  .post-foot {
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
  }

  /* ---- Long-form prose ---- */
  .prose {
    font-size: 1.075rem;
    line-height: 1.75;
    color: var(--fg);
  }
  .prose :global(> :first-child) {
    margin-top: 0;
  }
  .prose :global(p) {
    margin: 0 0 1.4rem;
  }
  .prose :global(h2) {
    font-size: 1.65rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 2.75rem 0 1rem;
  }
  .prose :global(h3) {
    font-size: 1.3rem;
    line-height: 1.3;
    margin: 2.25rem 0 0.85rem;
  }
  .prose :global(h4) {
    font-size: 1.1rem;
    margin: 2rem 0 0.75rem;
  }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    transition: border-color 0.2s ease;
  }
  .prose :global(a:hover) {
    border-bottom-color: var(--accent);
  }
  .prose :global(strong) {
    font-weight: 650;
    color: var(--fg);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.4rem;
    padding-left: 1.4rem;
  }
  .prose :global(li) {
    margin: 0.4rem 0;
  }
  .prose :global(li::marker) {
    color: var(--accent);
  }

  .prose :global(blockquote) {
    margin: 1.75rem 0;
    padding: 0.25rem 1.25rem;
    border-left: 3px solid var(--accent);
    background: var(--bg-elev);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--muted);
    font-style: italic;
  }
  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* Inline code */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) * 0.4);
    padding: 0.12em 0.4em;
  }
  /* Code blocks (Astro/Shiki wraps in <pre>) */
  .prose :global(pre) {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.6;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    margin: 0 0 1.6rem;
    overflow-x: auto;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.6rem;
    font-size: 0.95rem;
  }
  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--border);
  }
  .prose :global(th) {
    background: var(--bg-elev);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }
</style>
